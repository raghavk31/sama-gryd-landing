    },
    {
      "@id": "erDeg:loadCategory",
      "@type": "rdf:Property",
      "rdfs:label": "Load Category",
      "rdfs:comment": "Functional category of this load (Heating, Cooling, WaterHeating, Lighting, EV, Industrial, Other). CIM: ConformLoad classification.",
