{
  "@context": {
    "@version": 1.1,
    "beckn": "https://schema.beckn.io/core/v2.0/",
    "deg": "https://schema.beckn.io/deg/EvChargingService/v2.0/",
    "schema": "https://schema.org/",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "xsd": "http://www.w3.org/2001/XMLSchema#"
  },
  "@graph": [
    {
      "@id": "deg:ChargingService",
      "@type": "rdfs:Class",
      "rdfs:label": "EV Charging Service",
      "rdfs:comment": "A service that provides electric vehicle charging capabilities"
    },
    {
      "@id": "deg:ChargingStation",
      "@type": "rdfs:Class",
      "rdfs:label": "Charging Station",
      "rdfs:comment": "A charging station containing station identifier and location information."
    },
    {
      "@id": "deg:connectorType",
      "@type": "rdf:Property",
      "rdfs:label": "Connector type",
      "rdfs:comment": "Physical connector type supported by the EVSE/charger (e.g., CCS2, Type2, CHAdeMO, GB/T).",
      "rdfs:domain": "deg:ChargingService",
      "schema:rangeIncludes": "deg:ConnectorType"
    },
    {
      "@id": "deg:maxPowerKW",
      "@type": "rdf:Property",
      "rdfs:label": "Maximum power (kW)",
      "rdfs:comment": "Maximum charging power supported by the EVSE in kilowatts.",
      "rdfs:domain": "deg:ChargingService",
      "schema:rangeIncludes": "schema:Number"
    },
    {
      "@id": "deg:minPowerKW",
      "@type": "rdf:Property",
      "rdfs:label": "Minimum power (kW)",
      "rdfs:comment": "Minimum controllable charging power in kilowatts.",
      "rdfs:domain": "deg:ChargingService",
      "schema:rangeIncludes": "schema:Number"
    },
    {
      "@id": "deg:reservationSupported",
      "@type": "rdf:Property",
      "rdfs:label": "Reservation supported",
      "rdfs:comment": "Whether advance reservations are supported for this connector/site.",
      "rdfs:domain": "deg:ChargingService",
      "schema:rangeIncludes": "schema:Boolean"
    },
    {
      "@id": "deg:amenityFeature",
      "@type": "rdf:Property",
      "rdfs:label": "Amenity feature",
      "rdfs:comment": "Nearby amenities such as Restaurant, Restroom, Wi-Fi, Parking.",
      "rdfs:domain": "deg:ChargingService",
      "schema:rangeIncludes": "deg:AmenityFeature"
    },
    {
      "@id": "deg:evseId",
      "@type": "rdf:Property",
      "rdfs:label": "EVSE identifier",
      "rdfs:comment": "Public EVSE identifier (e.g., OCPI/Hubject style).",
      "rdfs:domain": "deg:ChargingService",
      "schema:rangeIncludes": "schema:Text"
    },
    {
      "@id": "deg:roamingNetwork",
      "@type": "rdf:Property",
      "rdfs:label": "Roaming network",
      "rdfs:comment": "Roaming federation or network name, if any.",
      "rdfs:domain": "deg:ChargingService",
      "schema:rangeIncludes": "schema:Text"
    },
    {
      "@id": "deg:parkingType",
      "@type": "rdf:Property",
      "rdfs:label": "Parking type",
      "rdfs:comment": "Type of parking facility (e.g., Mall, Office, FuelStation).",
      "rdfs:domain": "deg:ChargingService",
      "schema:rangeIncludes": "deg:ParkingType"
    },
    {
      "@id": "deg:powerType",
      "@type": "rdf:Property",
      "rdfs:label": "Power type",
      "rdfs:comment": "Electrical power type (AC_SINGLE_PHASE, AC_3_PHASE, DC).",
      "rdfs:domain": "deg:ChargingService",
      "schema:rangeIncludes": "deg:PowerType"
    },
    {
      "@id": "deg:connectorFormat",
      "@type": "rdf:Property",
      "rdfs:label": "Connector format",
      "rdfs:comment": "Physical presentation of the connector (SOCKET or CABLE).",
      "rdfs:domain": "deg:ChargingService",
      "schema:rangeIncludes": "deg:ConnectorFormat"
    },
    {
      "@id": "deg:chargingSpeed",
      "@type": "rdf:Property",
      "rdfs:label": "Charging speed band",
      "rdfs:comment": "Marketing speed band (SLOW, NORMAL, FAST, ULTRAFAST).",
      "rdfs:domain": "deg:ChargingService",
      "schema:rangeIncludes": "deg:ChargingSpeed"
    },
    {
      "@id": "deg:vehicleType",
      "@type": "rdf:Property",
      "rdfs:label": "Vehicle type",
      "rdfs:comment": "Type of vehicle that can use this charging service (2-WHEELER, 3-WHEELER, 4-WHEELER).",
      "rdfs:domain": "deg:ChargingService",
      "schema:rangeIncludes": "deg:VehicleType"
    },
    {
      "@id": "deg:chargingStation",
      "@type": "rdf:Property",
      "rdfs:label": "Charging station",
      "rdfs:comment": "Charging station information including station ID and location.",
      "rdfs:domain": "deg:ChargingService",
      "schema:rangeIncludes": "deg:ChargingStation"
    },
    {
      "@id": "deg:id",
      "@type": "rdf:Property",
      "rdfs:label": "Charging station ID",
      "rdfs:comment": "Unique identifier for the charging station (chargingStationId).",
      "rdfs:domain": "deg:ChargingStation",
      "schema:rangeIncludes": "schema:Text"
    },
    {
      "@id": "deg:serviceLocation",
      "@type": "rdf:Property",
      "rdfs:label": "Service location",
      "rdfs:comment": "Physical location where the charging service is offered; aligns to Beckn Location in payloads.",
      "rdfs:domain": "deg:ChargingStation",
      "schema:rangeIncludes": "schema:Place"
    },
    {
      "@id": "deg:AmenityFeature",
      "@type": "schema:Enumeration",
      "schema:name": "Amenity Feature",
      "rdfs:comment": "Enumeration of amenity features available near the charging service.",
      "schema:hasEnumerationMember": [
        {
          "@id": "deg:AmenityRestaurant"
        },
        {
          "@id": "deg:AmenityRestroom"
        },
        {
          "@id": "deg:AmenityWiFi"
        },
        {
          "@id": "deg:AmenityParking"
        }
      ]
    },
    {
      "@id": "deg:AmenityRestaurant",
      "@type": [
        "deg:AmenityFeature",
        "schema:Enumeration"
      ],
      "schema:name": "RESTAURANT",
      "schema:identifier": "RESTAURANT",
      "schema:alternateName": "Restaurant"
    },
    {
      "@id": "deg:AmenityRestroom",
      "@type": [
        "deg:AmenityFeature",
        "schema:Enumeration"
      ],
      "schema:name": "RESTROOM",
      "schema:identifier": "RESTROOM",
      "schema:alternateName": "Restroom"
    },
    {
      "@id": "deg:AmenityWiFi",
      "@type": [
        "deg:AmenityFeature",
        "schema:Enumeration"
      ],
      "schema:name": "WI-FI",
      "schema:identifier": "WI-FI",
      "schema:alternateName": [
        "Wi-Fi",
        "WiFi"
      ]
    },
    {
      "@id": "deg:AmenityParking",
      "@type": [
        "deg:AmenityFeature",
        "schema:Enumeration"
      ],
      "schema:name": "PARKING",
      "schema:identifier": "PARKING",
      "schema:alternateName": "Parking"
    },
    {
      "@id": "deg:ConnectorType",
      "@type": "schema:Enumeration",
      "schema:name": "Connector Type",
      "rdfs:comment": "Enumeration of electric vehicle connector interface types.",
      "schema:hasEnumerationMember": [
        {
          "@id": "deg:ConnectorTypeCCS2"
        },
        {
          "@id": "deg:ConnectorTypeType2"
        },
        {
          "@id": "deg:ConnectorTypeCHAdeMO"
        },
        {
          "@id": "deg:ConnectorTypeGBT"
        }
      ]
    },
    {
      "@id": "deg:ConnectorTypeCCS2",
      "@type": [
        "deg:ConnectorType",
        "schema:Enumeration"
      ],
      "schema:name": "CCS2",
      "schema:identifier": "CCS2"
    },
    {
      "@id": "deg:ConnectorTypeType2",
      "@type": [
        "deg:ConnectorType",
        "schema:Enumeration"
      ],
      "schema:name": "Type2",
      "schema:identifier": "Type2"
    },
    {
      "@id": "deg:ConnectorTypeCHAdeMO",
      "@type": [
        "deg:ConnectorType",
        "schema:Enumeration"
      ],
      "schema:name": "CHAdeMO",
      "schema:identifier": "CHAdeMO"
    },
    {
      "@id": "deg:ConnectorTypeGBT",
      "@type": [
        "deg:ConnectorType",
        "schema:Enumeration"
      ],
      "schema:name": "GB/T",
      "schema:identifier": "GB_T",
      "schema:alternateName": "GB-T"
    },
    {
      "@id": "deg:PowerType",
      "@type": "schema:Enumeration",
      "schema:name": "Power Type",
      "rdfs:comment": "Enumeration of supported electrical power types.",
      "schema:hasEnumerationMember": [
        {
          "@id": "deg:PowerTypeACSinglePhase"
        },
        {
          "@id": "deg:PowerTypeAC3Phase"
        },
        {
          "@id": "deg:PowerTypeDC"
        }
      ]
    },
    {
      "@id": "deg:PowerTypeACSinglePhase",
      "@type": [
        "deg:PowerType",
        "schema:Enumeration"
      ],
      "schema:name": "AC_SINGLE_PHASE",
      "schema:identifier": "AC_SINGLE_PHASE"
    },
    {
      "@id": "deg:PowerTypeAC3Phase",
      "@type": [
        "deg:PowerType",
        "schema:Enumeration"
      ],
      "schema:name": "AC_3_PHASE",
      "schema:identifier": "AC_3_PHASE",
      "schema:alternateName": "AC_THREE_PHASE"
    },
    {
      "@id": "deg:PowerTypeDC",
      "@type": [
        "deg:PowerType",
        "schema:Enumeration"
      ],
      "schema:name": "DC",
      "schema:identifier": "DC"
    },
    {
      "@id": "deg:ConnectorFormat",
      "@type": "schema:Enumeration",
      "schema:name": "Connector Format",
      "rdfs:comment": "Enumeration of connector presentation formats.",
      "schema:hasEnumerationMember": [
        {
          "@id": "deg:ConnectorFormatSocket"
        },
        {
          "@id": "deg:ConnectorFormatCable"
        }
      ]
    },
    {
      "@id": "deg:ConnectorFormatSocket",
      "@type": [
        "deg:ConnectorFormat",
        "schema:Enumeration"
      ],
      "schema:name": "SOCKET",
      "schema:identifier": "SOCKET"
    },
    {
      "@id": "deg:ConnectorFormatCable",
      "@type": [
        "deg:ConnectorFormat",
        "schema:Enumeration"
      ],
      "schema:name": "CABLE",
      "schema:identifier": "CABLE"
    },
    {
      "@id": "deg:ChargingSpeed",
      "@type": "schema:Enumeration",
      "schema:name": "Charging Speed",
      "rdfs:comment": "Enumeration of marketing charging speed bands.",
      "schema:hasEnumerationMember": [
        {
          "@id": "deg:ChargingSpeedSlow"
        },
        {
          "@id": "deg:ChargingSpeedNormal"
        },
        {
          "@id": "deg:ChargingSpeedFast"
        },
        {
          "@id": "deg:ChargingSpeedUltraFast"
        }
      ]
    },
    {
      "@id": "deg:ChargingSpeedSlow",
      "@type": [
        "deg:ChargingSpeed",
        "schema:Enumeration"
      ],
      "schema:name": "SLOW",
      "schema:identifier": "SLOW"
    },
    {
      "@id": "deg:ChargingSpeedNormal",
      "@type": [
        "deg:ChargingSpeed",
        "schema:Enumeration"
      ],
      "schema:name": "NORMAL",
      "schema:identifier": "NORMAL"
    },
    {
      "@id": "deg:ChargingSpeedFast",
      "@type": [
        "deg:ChargingSpeed",
        "schema:Enumeration"
      ],
      "schema:name": "FAST",
      "schema:identifier": "FAST"
    },
    {
      "@id": "deg:ChargingSpeedUltraFast",
      "@type": [
        "deg:ChargingSpeed",
        "schema:Enumeration"
      ],
      "schema:name": "ULTRAFAST",
      "schema:identifier": "ULTRAFAST",
      "schema:alternateName": "Ultra Fast"
    },
    {
      "@id": "deg:ParkingType",
      "@type": "schema:Enumeration",
      "schema:name": "Parking Type",
      "rdfs:comment": "Enumeration of parking facility types available at the charging location.",
      "schema:hasEnumerationMember": [
        {
          "@id": "deg:ParkingTypeOnStreet"
        },
        {
          "@id": "deg:ParkingTypeOffStreet"
        },
        {
          "@id": "deg:ParkingTypeBasement"
        },
        {
          "@id": "deg:ParkingTypeMall"
        },
        {
          "@id": "deg:ParkingTypeFuelStation"
        },
        {
          "@id": "deg:ParkingTypeOffice"
        },
        {
          "@id": "deg:ParkingTypeHotel"
        }
      ]
    },
    {
      "@id": "deg:ParkingTypeOnStreet",
      "@type": [
        "deg:ParkingType",
        "schema:Enumeration"
      ],
      "schema:name": "OnStreet",
      "schema:identifier": "OnStreet",
      "schema:alternateName": "On Street"
    },
    {
      "@id": "deg:ParkingTypeOffStreet",
      "@type": [
        "deg:ParkingType",
        "schema:Enumeration"
      ],
      "schema:name": "OffStreet",
      "schema:identifier": "OffStreet",
      "schema:alternateName": "Off Street"
    },
    {
      "@id": "deg:ParkingTypeBasement",
      "@type": [
        "deg:ParkingType",
        "schema:Enumeration"
      ],
      "schema:name": "Basement",
      "schema:identifier": "Basement"
    },
    {
      "@id": "deg:ParkingTypeMall",
      "@type": [
        "deg:ParkingType",
        "schema:Enumeration"
      ],
      "schema:name": "Mall",
      "schema:identifier": "Mall"
    },
    {
      "@id": "deg:ParkingTypeFuelStation",
      "@type": [
        "deg:ParkingType",
        "schema:Enumeration"
      ],
      "schema:name": "FuelStation",
      "schema:identifier": "FuelStation",
      "schema:alternateName": "Fuel Station"
    },
    {
      "@id": "deg:ParkingTypeOffice",
      "@type": [
        "deg:ParkingType",
        "schema:Enumeration"
      ],
      "schema:name": "Office",
      "schema:identifier": "Office"
    },
    {
      "@id": "deg:ParkingTypeHotel",
      "@type": [
        "deg:ParkingType",
        "schema:Enumeration"
      ],
      "schema:name": "Hotel",
      "schema:identifier": "Hotel"
    },
    {
      "@id": "deg:VehicleType",
      "@type": "schema:Enumeration",
      "schema:name": "Vehicle Type",
      "rdfs:comment": "Enumeration of vehicle types that can use the charging service.",
      "schema:hasEnumerationMember": [
        {
          "@id": "deg:VehicleType2Wheeler"
        },
        {
          "@id": "deg:VehicleType3Wheeler"
        },
        {
          "@id": "deg:VehicleType4Wheeler"
        }
      ]
    },
    {
      "@id": "deg:VehicleType2Wheeler",
      "@type": [
        "deg:VehicleType",
