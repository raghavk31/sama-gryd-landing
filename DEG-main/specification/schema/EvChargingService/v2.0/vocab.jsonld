      "schema:identifier": "3-WHEELER"
    },
    {
      "@id": "deg:VehicleType4Wheeler",
      "@type": [
        "deg:VehicleType",
        "schema:Enumeration"
      ],
      "schema:name": "4-WHEELER",
      "schema:identifier": "4-WHEELER"
    }
  ]
