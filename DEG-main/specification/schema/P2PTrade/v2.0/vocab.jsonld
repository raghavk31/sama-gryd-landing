    },
    {
      "@id": "degLegacy:claimVerifier",
      "@type": "rdf:Property",
      "rdfs:label": "Claim verifier (EnergyTrade/v2.0 deprecated)",
      "rdfs:comment": "Deprecated. Use deg:claimVerifier.",
      "owl:deprecated": true,
      "owl:equivalentProperty": { "@id": "deg:claimVerifier" }
    },
    {
      "@id": "degLegacy:expiresAt",
      "@type": "rdf:Property",
      "rdfs:label": "Expires at (EnergyTrade/v2.0 deprecated)",
      "rdfs:comment": "Deprecated. Use deg:expiresAt.",
      "owl:deprecated": true,
      "owl:equivalentProperty": { "@id": "deg:expiresAt" }
    },
    {
      "@id": "degLegacy:bap_id",
      "@type": "rdf:Property",
      "rdfs:label": "BAP ID (EnergyTrade/v2.0 deprecated)",
      "rdfs:comment": "Deprecated. Use deg:bap_id.",
      "owl:deprecated": true,
      "owl:equivalentProperty": { "@id": "deg:bap_id" }
    },
    {
      "@id": "degLegacy:bpp_id",
