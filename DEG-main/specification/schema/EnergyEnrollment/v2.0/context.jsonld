      },
      "UserAuth": "deg:UserAuth",
      "UserAuthRequest": "deg:UserAuthRequest",
      "UserAuthResponse": "deg:UserAuthResponse",
      "OtpAuthRequest": "deg:OtpAuthRequest",
      "OtpAuthResponse": "deg:OtpAuthResponse",
      "OAuth2AuthRequest": "deg:OAuth2AuthRequest",
      "OAuth2AuthResponse": "deg:OAuth2AuthResponse",
      "MeterEnrollment": "deg:MeterEnrollment",
