    "DemandFlexBuyOffer": "deg:DemandFlexBuyOffer",
    "DemandFlexProvider": "deg:DemandFlexProvider",
    "incentivePerKwh": "deg:incentivePerKwh",
    "currency": "deg:currency",
    "maxEventsPerMonth": "deg:maxEventsPerMonth",
    "baselineMethodology": "deg:baselineMethodology",
    "bestOf": "deg:bestOf",
    "outOf": "deg:outOf",
    "penaltyRate": "deg:penaltyRate",
    "premiumForGuaranteed": "deg:premiumForGuaranteed",
    "optOutDefault": "deg:optOutDefault",
    "taker": "deg:taker",
    "policy": "deg:policy",
    "url": "deg:url",
    "queryPath": "deg:queryPath",
    "bundleUrl": "deg:bundleUrl",
    "plannedDemandChange": "deg:plannedDemandChange",
