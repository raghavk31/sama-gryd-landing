{
    "@context": {
        "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
        "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
        "xsd": "http://www.w3.org/2001/XMLSchema#",
        "skos": "http://www.w3.org/2004/02/skos/core#",
        "oadr": "https://www.openadr.org/oadr3#"
    },
    "@graph": [
        {
            "@id": "oadr:interval",
            "@type": "rdfs:Class",
            "rdfs:label": "Interval",
            "rdfs:comment": "A temporal window with an integer id and a list of typed valuesMap payloads. An optional per-interval intervalPeriod overrides the series-level default.",
            "skos:exactMatch": { "@id": "https://www.openadr.org/oadr3#interval" }
        },
        {
            "@id": "oadr:intervalPeriod",
            "@type": "rdfs:Class",
            "rdfs:label": "Interval Period",
            "rdfs:comment": "Temporal bounds of an interval series or a single interval. start uses RFC 3339 format; duration uses ISO 8601 format (e.g. PT1H).",
            "skos:exactMatch": { "@id": "https://www.openadr.org/oadr3#intervalPeriod" }
        },
        {
            "@id": "oadr:valuesMap",
            "@type": "rdfs:Class",
            "rdfs:label": "Values Map",
            "rdfs:comment": "A typed payload row: type names the signal (e.g. PRICE_PER_KWH, AVAILABLE_QTY); values carries one or more data points.",
            "skos:exactMatch": { "@id": "https://www.openadr.org/oadr3#valuesMap" }
        },
        {
            "@id": "oadr:point",
            "@type": "rdfs:Class",
            "rdfs:label": "Point",
            "rdfs:comment": "An (x, y) float pair, typically a 2-D grid coordinate.",
            "skos:exactMatch": { "@id": "https://www.openadr.org/oadr3#point" }
        },
        {
            "@id": "oadr:eventPayloadDescriptor",
            "@type": "rdfs:Class",
            "rdfs:label": "Event Payload Descriptor",
            "rdfs:comment": "Sidecar metadata for a signal carried in an event or offer (objectType: EVENT_PAYLOAD_DESCRIPTOR). Provides units and currency context for a payloadType.",
            "skos:exactMatch": { "@id": "https://www.openadr.org/oadr3#eventPayloadDescriptor" }
        },
        {
            "@id": "oadr:reportPayloadDescriptor",
            "@type": "rdfs:Class",
            "rdfs:label": "Report Payload Descriptor",
            "rdfs:comment": "Sidecar metadata for a telemetry signal in a report (objectType: REPORT_PAYLOAD_DESCRIPTOR). Provides units, reading type, accuracy, and confidence context.",
            "skos:exactMatch": { "@id": "https://www.openadr.org/oadr3#reportPayloadDescriptor" }
        },

        {
            "@id": "oadr:id",
            "@type": "rdf:Property",
            "rdfs:label": "id",
            "rdfs:comment": "Client-assigned integer index for an interval. Not required to be sequential.",
            "rdfs:domain": { "@id": "oadr:interval" },
            "rdfs:range": { "@id": "xsd:integer" }
        },
        {
            "@id": "oadr:payloads",
            "@type": "rdf:Property",
            "rdfs:label": "payloads",
            "rdfs:comment": "One valuesMap row per signal type carried by this interval.",
            "rdfs:domain": { "@id": "oadr:interval" },
            "rdfs:range": { "@id": "oadr:valuesMap" }
        },
        {
            "@id": "oadr:start",
            "@type": "rdf:Property",
            "rdfs:label": "start",
            "rdfs:comment": "RFC 3339 start timestamp for an interval period.",
            "rdfs:domain": { "@id": "oadr:intervalPeriod" },
            "rdfs:range": { "@id": "xsd:dateTime" }
        },
        {
            "@id": "oadr:duration",
            "@type": "rdf:Property",
            "rdfs:label": "duration",
            "rdfs:comment": "ISO 8601 duration string (e.g. PT1H). Used in intervalPeriod.",
            "rdfs:range": { "@id": "xsd:string" }
        },
        {
            "@id": "oadr:randomizeStart",
            "@type": "rdf:Property",
            "rdfs:label": "randomize start",
            "rdfs:comment": "ISO 8601 duration defining the maximum random offset that may be applied to start.",
            "rdfs:domain": { "@id": "oadr:intervalPeriod" },
            "rdfs:range": { "@id": "xsd:string" }
        },
        {
            "@id": "oadr:payloadType",
            "@type": "rdf:Property",
            "rdfs:label": "payload type",
            "rdfs:comment": "Signal type name matching the type field in valuesMap rows (e.g. PRICE, USAGE, AVAILABLE_QTY).",
            "rdfs:range": { "@id": "xsd:string" }
        },
        {
            "@id": "oadr:objectType",
            "@type": "rdf:Property",
            "rdfs:label": "object type",
            "rdfs:comment": "Discriminator for payload descriptor variants: EVENT_PAYLOAD_DESCRIPTOR or REPORT_PAYLOAD_DESCRIPTOR.",
            "rdfs:range": { "@id": "xsd:string" }
        },
        {
            "@id": "oadr:units",
            "@type": "rdf:Property",
            "rdfs:label": "units",
            "rdfs:comment": "Unit of measure label (e.g. KWH, KW, STRING, DEGREES).",
            "rdfs:range": { "@id": "xsd:string" }
        },
        {
            "@id": "oadr:currency",
            "@type": "rdf:Property",
            "rdfs:label": "currency",
            "rdfs:comment": "ISO 4217 currency code for price-type payloads (e.g. INR, USD).",
            "rdfs:range": { "@id": "xsd:string" }
        },
        {
            "@id": "oadr:readingType",
            "@type": "rdf:Property",
            "rdfs:label": "reading type",
            "rdfs:comment": "Reading type qualifier (e.g. DIRECT_READ). See OpenADR 3.1.0 Definitions for standardised values.",
            "rdfs:range": { "@id": "xsd:string" }
        },
        {
            "@id": "oadr:accuracy",
            "@type": "rdf:Property",
            "rdfs:label": "accuracy",
            "rdfs:comment": "Quantification of payload accuracy as a float.",
            "rdfs:domain": { "@id": "oadr:reportPayloadDescriptor" },
            "rdfs:range": { "@id": "xsd:decimal" }
        },
        {
            "@id": "oadr:confidence",
            "@type": "rdf:Property",
            "rdfs:label": "confidence",
            "rdfs:comment": "Confidence percentage (0–100) for this payload set.",
            "rdfs:domain": { "@id": "oadr:reportPayloadDescriptor" },
            "rdfs:range": { "@id": "xsd:integer" }
        },
        {
            "@id": "oadr:type",
            "@type": "rdf:Property",
            "rdfs:label": "type",
            "rdfs:comment": "Signal type identifier in a valuesMap row.",
            "rdfs:domain": { "@id": "oadr:valuesMap" },
            "rdfs:range": { "@id": "xsd:string" }
        },
        {
            "@id": "oadr:values",
            "@type": "rdf:Property",
            "rdfs:label": "values",
            "rdfs:comment": "Data points array for a valuesMap signal.",
            "rdfs:domain": { "@id": "oadr:valuesMap" }
        },
        {
            "@id": "oadr:x",
            "@type": "rdf:Property",
            "rdfs:label": "x",
            "rdfs:comment": "Value on the x axis of a point.",
            "rdfs:domain": { "@id": "oadr:point" },
            "rdfs:range": { "@id": "xsd:decimal" }
        },
        {
            "@id": "oadr:y",
            "@type": "rdf:Property",
            "rdfs:label": "y",
            "rdfs:comment": "Value on the y axis of a point.",
            "rdfs:domain": { "@id": "oadr:point" },
            "rdfs:range": { "@id": "xsd:decimal" }
        }
    ]
}
