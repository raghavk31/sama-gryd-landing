            "body": {
              "mode": "raw",
              "raw": "{\n  \"context\": {\n    \"networkId\": \"{{domain}}\",\n    \"version\": \"{{version}}\",\n    \"action\": \"on_status\",\n    \"bapId\": \"{{bap_id}}\",\n    \"bapUri\": \"{{bap_host_root}}/bap/receiver\",\n    \"bppId\": \"{{bpp_id}}\",\n    \"bppUri\": \"{{bpp_host_root}}/bpp/caller\",\n    \"transactionId\": \"{{transaction_id}}\",\n    \"messageId\": \"{{$guid}}\",\n    \"timestamp\": \"{{iso_date}}\",\n    \"schemaContext\": [\n      \"https://raw.githubusercontent.com/beckn/DDM/main/specification/schema/DatasetItem/v1/context.jsonld\",\n      \"https://schema.beckn.io/BecknTimeSeries/v1.0/context.jsonld\"\n    ]\n  },\n  \"message\": {\n    \"contract\": {\n      \"id\": \"contract-p2p-001\",\n      \"status\": {\n        \"code\": \"ACTIVE\"\n      },\n      \"commitments\": [\n        {\n          \"id\": \"commitment-p2p-001\",\n          \"status\": {\n            \"descriptor\": {\n              \"code\": \"ACTIVE\"\n            }\n          },\n          \"resources\": [\n            {\n              \"id\": \"ds-actuals-buyer-001\",\n              \"descriptor\": {\n                \"name\": \"Buyer-discom meter actuals\"\n              },\n              \"quantity\": {\n                \"@type\": \"Quantity\",\n                \"unitText\": \"report\",\n                \"unitCode\": \"EA\",\n                \"value\": \"1\"\n              },\n              \"resourceAttributes\": {\n                \"@context\": \"https://raw.githubusercontent.com/beckn/DDM/main/specification/schema/DatasetItem/v1/context.jsonld\",\n                \"@type\": \"DatasetItem\",\n                \"schema:identifier\": \"ds-actuals-buyer-001\",\n                \"schema:name\": \"Buyer-discom meter actuals\",\n                \"schema:temporalCoverage\": \"2026-04-26T04:30:00Z/2026-04-26T05:30:00Z\",\n                \"dataPayload\": {\n                  \"@context\": \"https://schema.beckn.io/BecknTimeSeries/v1.0/context.jsonld\",\n                  \"@type\": \"TimeSeries\",\n                  \"resourceName\": \"TEST_METER_BUYER_001\",\n                  \"clientName\": \"TEST_DISCOM_BUYER\",\n                  \"intervalPeriod\": {\n                    \"start\": \"2026-04-26T04:30:00Z\",\n                    \"duration\": \"PT1H\"\n                  },\n                  \"payloadDescriptors\": [\n                    {\"objectType\": \"REPORT_PAYLOAD_DESCRIPTOR\", \"payloadType\": \"ENERGY_CONSUMPTION\", \"units\": \"KWH\"}\n                  ],\n                  \"intervals\": [\n                    {\"id\": 0, \"payloads\": [{\"type\": \"ENERGY_CONSUMPTION\", \"values\": [19.2]}]}\n                  ]\n                }\n              }\n            }\n          ],\n          \"offer\": {\n            \"id\": \"offer-001\",\n            \"resourceIds\": [\"ds-actuals-buyer-001\"]\n          }\n        }\n      ]\n    }\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
